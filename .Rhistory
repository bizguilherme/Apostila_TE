x1 <- 18; n1 <- 100
x2 <- 30; n2 <- 120
p1 <- x1/n1
p2 <- x2/n2
z <- qnorm(0.975)
EP <- sqrt((p1*(1-p1))/n1 + (p2*(1-p2))/n2)
IC_inf <- (p1 - p2) - z*EP
IC_sup <- (p1 - p2) + z*EP
IC_inf
IC_sup
