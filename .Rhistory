set.seed(123)
# Distribuição simétrica
simetrica <- rnorm(1000, mean = 50, sd = 10)
# Assimétrica à direita
assim_dir <- rexp(1000, rate = 0.1) + 20
# Assimétrica à esquerda
assim_esq <- max(assim_dir) - assim_dir + 20
# Densidades
d1 <- density(simetrica)
d2 <- density(assim_dir)
d3 <- density(assim_esq)
# Plot
plot(d1, col = "black", lwd = 2,
main = "Densidade das distribuições",
xlab = "Valores",ylim=c(0,max(simetrica,assim_dir,assim_esq)),las=1,ylab="Densidade")
max(simetrica,assim_dir,assim_esq)
# Densidades
d1 <- density(simetrica)
d2 <- density(assim_dir)
d3 <- density(assim_esq)
